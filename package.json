{
  "name": "zigma-workspace",
  "version": "0.1.0",
  "description": "Zigma workspace management CLI",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/api/index.js"
  },
  "bin": {
    "zigma-workspace": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && tsc",
    "check": "npm run typecheck && npm run build && npm run test",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "npm run test:smoke",
    "test:smoke": "node dist/cli/index.js --help",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LummiGhost/zigma-workspace.git"
  },
  "homepage": "https://github.com/LummiGhost/zigma-workspace#readme",
  "bugs": {
    "url": "https://github.com/LummiGhost/zigma-workspace/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "commander": "^12.1.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
